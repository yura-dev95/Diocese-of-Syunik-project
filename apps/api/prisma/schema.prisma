generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  EDITOR
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SubmissionStatus {
  NEW
  IN_REVIEW
  RESOLVED
  ARCHIVED
}

enum ChurchCategory {
  ACTIVE_MONASTERY
  CITY_CHURCH
  VILLAGE_CHURCH
  RUINED_SANCTUARY
  CHAPEL
}

enum LibraryCategory {
  PDF
  MANUSCRIPT
  ARTICLE
}

enum PaymentProvider {
  MOCK
  ARCA
  VISA
  PAYPAL
  APPLE_PAY
  GOOGLE_PAY
}

enum PaymentStatus {
  INTENT_CREATED
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum MediaType {
  SERMON
  PODCAST
  VLOG
  SHARAKAN
  CHOIR_RECORDING
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(EDITOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Church {
  id               String            @id @default(cuid())
  slug             String            @unique
  name             String
  summary          String?
  description      String?
  address          String?
  settlement       String?
  century          String?
  category         ChurchCategory    @default(VILLAGE_CHURCH)
  coverUrl         String?
  latitude         Decimal?
  longitude        Decimal?
  visitingNote     String?
  serviceSchedule  String?
  isFeatured       Boolean           @default(false)
  isActive         Boolean           @default(true)
  status           ContentStatus     @default(DRAFT)
  clergy           ClergyMember[]
  gallery          GalleryImage[]
  liturgySchedules LiturgySchedule[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model PilgrimRoute {
  id               String        @id @default(cuid())
  slug             String        @unique
  title            String
  summary          String
  duration         String
  distanceKm       Decimal?
  difficulty       String
  coverUrl         String?
  startLocation    String
  endLocation      String
  itinerary        Json
  transportOptions Json?
  mapFileUrl       String?
  status           ContentStatus @default(DRAFT)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model LiturgySchedule {
  id          String        @id @default(cuid())
  dayLabel    String
  timeLabel   String
  serviceType String
  note        String?
  status      ContentStatus @default(DRAFT)
  churchId    String
  church      Church        @relation(fields: [churchId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model UsefulContact {
  id          String        @id @default(cuid())
  name        String
  category    String
  description String?
  phone       String?
  email       String?
  address     String?
  website     String?
  isPublic    Boolean       @default(true)
  status      ContentStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model EtiquetteRule {
  id          String        @id @default(cuid())
  title       String
  description String
  iconKey     String?
  sortOrder   Int           @default(0)
  status      ContentStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model ClergyMember {
  id             String        @id @default(cuid())
  slug           String        @unique
  fullName       String
  title          String
  biography      String?
  imageUrl       String?
  ordinationYear Int?
  education      String?
  ministryFocus  String?
  publicEmail    String?
  socialLinks    Json?
  isPrimate      Boolean       @default(false)
  status         ContentStatus @default(DRAFT)
  churchId       String?
  church         Church?       @relation(fields: [churchId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model OfficialDocument {
  id           String        @id @default(cuid())
  slug         String        @unique
  title        String
  description  String?
  documentType String
  documentDate DateTime
  fileUrl      String?
  status       ContentStatus @default(DRAFT)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model SocialProgram {
  id             String                 @id @default(cuid())
  slug           String                 @unique
  title          String
  summary        String?
  description    String?
  coverUrl       String?
  location       String?
  beneficiaries  Int?
  startsAt       DateTime?
  endsAt         DateTime?
  isFeatured     Boolean                @default(false)
  goalAmount     Decimal?
  raisedAmount   Decimal                @default(0)
  status         ContentStatus          @default(DRAFT)
  donations      Donation[]
  volunteers     VolunteerApplication[]
  successStories SuccessStory[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
}

model Donation {
  id                String          @id @default(cuid())
  amount            Decimal
  currency          String          @default("AMD")
  donorName         String?
  donorEmail        String?
  isAnonymous       Boolean         @default(false)
  paymentProvider   PaymentProvider @default(MOCK)
  paymentStatus     PaymentStatus   @default(INTENT_CREATED)
  providerReference String?         @unique
  programId         String?
  program           SocialProgram?  @relation(fields: [programId], references: [id], onDelete: SetNull)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model VolunteerApplication {
  id           String           @id @default(cuid())
  fullName     String
  email        String
  phone        String?
  interests    String?
  availability String?
  message      String?
  status       SubmissionStatus @default(NEW)
  programId    String?
  program      SocialProgram?   @relation(fields: [programId], references: [id], onDelete: SetNull)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model SuccessStory {
  id          String         @id @default(cuid())
  slug        String         @unique
  title       String
  summary     String
  content     String?
  imageUrl    String?
  impactLabel String?
  status      ContentStatus  @default(DRAFT)
  programId   String?
  program     SocialProgram? @relation(fields: [programId], references: [id], onDelete: SetNull)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model DonorHonor {
  id          String        @id @default(cuid())
  displayName String
  honorLevel  String
  message     String?
  sortOrder   Int           @default(0)
  isAnonymous Boolean       @default(false)
  status      ContentStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model NewsArticle {
  id          String         @id @default(cuid())
  slug        String         @unique
  title       String
  excerpt     String?
  content     String?
  coverUrl    String?
  category    String?
  authorName  String?
  isFeatured  Boolean        @default(false)
  status      ContentStatus  @default(DRAFT)
  publishedAt DateTime?
  gallery     GalleryImage[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model Announcement {
  id               String        @id @default(cuid())
  slug             String        @unique
  title            String
  description      String
  announcementDate DateTime
  expiresAt        DateTime?
  priority         Int           @default(0)
  status           ContentStatus @default(DRAFT)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model GalleryImage {
  id        String       @id @default(cuid())
  url       String
  alt       String
  caption   String?
  category  String?
  sortOrder Int          @default(0)
  churchId  String?
  church    Church?      @relation(fields: [churchId], references: [id], onDelete: Cascade)
  articleId String?
  article   NewsArticle? @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())
}

model Event {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  description String?
  location    String?
  startsAt    DateTime
  endsAt      DateTime?
  status      ContentStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Prayer {
  id        String        @id @default(cuid())
  slug      String        @unique
  title     String
  category  String
  content   String
  summary   String?
  audioUrl  String?
  status    ContentStatus @default(DRAFT)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Saint {
  id        String        @id @default(cuid())
  slug      String        @unique
  name      String
  biography String?
  feastDate String?
  patronOf  String?
  imageUrl  String?
  status    ContentStatus @default(DRAFT)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model FeastDay {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  description String?
  feastDate   String
  isMovable   Boolean       @default(false)
  status      ContentStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model SacramentGuide {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  summary     String
  content     String
  preparation Json?
  status      ContentStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Choir {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String
  description String?
  imageUrl    String?
  conductor   String?
  location    String?
  status      ContentStatus @default(DRAFT)
  media       MediaItem[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model MediaItem {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  description String?
  mediaType   MediaType
  mediaUrl    String?
  coverUrl    String?
  duration    String?
  publishedAt DateTime?
  status      ContentStatus @default(DRAFT)
  choirId     String?
  choir       Choir?        @relation(fields: [choirId], references: [id], onDelete: SetNull)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model LibraryItem {
  id              String          @id @default(cuid())
  slug            String          @unique
  title           String
  author          String?
  description     String?
  category        LibraryCategory
  publicationYear Int?
  pageCount       Int?
  language        String?
  fileUrl         String?
  coverUrl        String?
  status          ContentStatus   @default(DRAFT)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model FAQ {
  id        String        @id @default(cuid())
  question  String
  answer    String
  category  String?
  sortOrder Int           @default(0)
  status    ContentStatus @default(DRAFT)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model ContactMessage {
  id        String           @id @default(cuid())
  fullName  String
  email     String
  phone     String?
  subject   String?
  message   String
  status    SubmissionStatus @default(NEW)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model QnAQuestion {
  id           String           @id @default(cuid())
  question     String
  answer       String?
  contactEmail String?
  category     String?
  isAnonymous  Boolean          @default(true)
  isPublic     Boolean          @default(false)
  status       SubmissionStatus @default(NEW)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}
